# 1. Ładowanie pomocnika Fluttera (Tego brakowało!)
flutter_install_all_ios_pods_file = File.expand_path(File.join('..', '..', '..', 'flutter', 'packages', 'flutter_tools', 'bin', 'xcode_backend.dart'), __FILE__)
# Jeśli powyższa ścieżka nie zadziała w Codemagic, używamy standardowego podejścia:
load File.join(File.dirname(File.realpath(__FILE__)), 'Generated.xcconfig') rescue nil

# 2. Definicja wersji Firebase (naprawia błąd [nil])
def firebase_sdk_version
  '11.0.0'
end

platform :ios, '15.0'
use_modular_headers!

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Firebase
  pod 'Firebase/Firestore', firebase_sdk_version
  pod 'Firebase/Auth', firebase_sdk_version
  pod 'Firebase/Core', firebase_sdk_version

  # Tę linię Codemagic wygeneruje automatycznie, jeśli używasz standardowego Fluttera
  # Ale bezpieczniej jest użyć tej komendy:
  target_properties = parse_KV_file(File.join(File.dirname(__FILE__), 'Config', 'Release.xcconfig')) rescue nil
end

# Sekcja naprawcza
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
    end
  end
end