# 1. Wymuszenie szybkiego źródła CDN (kluczowe dla Codemagic)
source 'https://cdn.cocoapods.org/'

platform :ios, '15.0'

require File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)

target 'Runner' do
  # Zmieniamy na dynamiczne linkowanie - bezpieczniejsze dla Google Sign In
  use_frameworks! 
  use_modular_headers!

  # 2. Usuwamy sztywne wpisy 'pod Firebase...'. 
  # Flutter sam je doda na podstawie pubspec.yaml w wersji, która NIE gryzie się z google_sign_in.

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Wymuszamy spójność wersji iOS dla wszystkich bibliotek
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Naprawa błędu "Arcade" i innych problemów z kompilacją na nowym Xcode
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'PERMISSION_CAMERA=1', 'PERMISSION_PHOTOS=1']
    end
  end
end