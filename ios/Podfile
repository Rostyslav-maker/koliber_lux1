# 1. Definicja wersji Firebase (naprawia błąd [nil])
def firebase_sdk_version
  '11.0.0'
end

# 2. Standardowe ładowanie pomocnika Fluttera
prepare_performance_setup = File.join(File.dirname(File.realpath(__FILE__)), '..', '..', 'flutter', 'packages', 'flutter_tools', 'bin', 'xcode_backend.dart')

platform :ios, '15.0'

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Ręczne dodanie Firebase, aby uniknąć błędów wersji
  pod 'Firebase/Firestore', firebase_sdk_version
  pod 'Firebase/Auth', firebase_sdk_version
  pod 'Firebase/Core', firebase_sdk_version

  # Ta sekcja pozwala Flutterowi na automatyczne dodanie reszty pluginów
  if File.exist?(File.join(File.dirname(__FILE__), 'Podfile.lock'))
    # Pozwala na uniknięcie konfliktów przy czystych buildach
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
    end
  end
end