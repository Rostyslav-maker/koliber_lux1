# Podfile dla Koliber Lux
platform :ios, '15.0'

# Nie zmieniaj nic poniżej tego wiersza
prepare_command "ruby -e \"require 'fileutils'; FileUtils.touch('Flutter/Generated.xcconfig') unless File.exists?('Flutter/Generated.xcconfig')\""

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Wymuszenie wersji 15.0 dla wszystkich bibliotek (np. cloud_firestore)
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
